{
  "name": "justwant",
  "private": true,
  "version": "0.0.0",
  "description": "Just want to make coding more fun",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elydelva/justwant.git"
  },
  "workspaces": ["apps/*", "packages/*", "examples/*"],
  "scripts": {
    "build": "bun run --filter './packages/*' --filter './apps/*' build",
    "test": "bun test",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "version": "changeset version",
    "publish:packages": "changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.10",
    "bun-types": "^1.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "typescript": "^5.7.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": "biome check --write"
  },
  "overrides": {
    "@duckdb/node-api": "1.4.0-r.2"
  }
}
