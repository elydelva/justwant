{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "ignore": [
    "examples/**",
    "**/*.type-test.ts"
  ],
  "workspaces": {
    ".": {
      "entry": [],
      "project": ["packages/*/src/**/*.ts"]
    },
    "packages/*": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"],
      "ignore": ["src/**/*.test.ts", "src/**/*.spec.ts", "src/**/*.type-test.ts"]
    }
  },
  "ignoreDependencies": ["bun-types", "typescript"],
  "ignoreExportsUsedInFile": true,
  "ignoreBinaries": ["sleep"]
}
