{
  "name": "@justwant/id",
  "version": "0.1.0",
  "description": "ID generation: sortable (by time) and short (URL-safe). Simple names, tool-agnostic. Subpath imports only.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/elydelva/justwant",
    "directory": "packages/id"
  },
  "keywords": [
    "id",
    "ulid",
    "nanoid",
    "unique-id",
    "sortable",
    "url-safe"
  ],
  "sideEffects": false,
  "exports": {
    "./sortable": {
      "types": "./dist/sortable.d.ts",
      "import": "./dist/sortable.js",
      "default": "./dist/sortable.js"
    },
    "./short": {
      "types": "./dist/short.d.ts",
      "import": "./dist/short.js",
      "default": "./dist/short.js"
    },
    "./primitives": {
      "types": "./dist/primitives.d.ts",
      "import": "./dist/primitives.js",
      "default": "./dist/primitives.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "nanoid": "^5.0.0",
    "ulid": "^3.0.0"
  },
  "devDependencies": {
    "@justwant/tsconfig": "workspace:*",
    "typescript": "^5.7.0"
  }
}
