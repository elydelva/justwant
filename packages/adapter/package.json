{
  "name": "@justwant/adapter",
  "version": "0.2.0",
  "description": "Adapter contracts, base types, Drizzle and Prisma implementations",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/elydelva/justwant",
    "directory": "packages/adapter"
  },
  "keywords": ["adapter", "orm", "contract", "typescript", "drizzle", "prisma"],
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./base": {
      "types": "./dist/base/index.d.ts",
      "import": "./dist/base/index.js",
      "default": "./dist/base/index.js"
    },
    "./contract": {
      "types": "./dist/base/contract.d.ts",
      "import": "./dist/base/contract.js",
      "default": "./dist/base/contract.js"
    },
    "./table": {
      "types": "./dist/base/table.d.ts",
      "import": "./dist/base/table.js",
      "default": "./dist/base/table.js"
    },
    "./adapter": {
      "types": "./dist/base/adapter.d.ts",
      "import": "./dist/base/adapter.js",
      "default": "./dist/base/adapter.js"
    },
    "./errors": {
      "types": "./dist/base/errors.d.ts",
      "import": "./dist/base/errors.js",
      "default": "./dist/base/errors.js"
    },
    "./drizzle": {
      "types": "./dist/drizzle/index.d.ts",
      "import": "./dist/drizzle/index.js",
      "default": "./dist/drizzle/index.js"
    },
    "./drizzle/defineMappedTable": {
      "types": "./dist/drizzle/defineMappedTable.d.ts",
      "import": "./dist/drizzle/defineMappedTable.js",
      "default": "./dist/drizzle/defineMappedTable.js"
    },
    "./drizzle/buildWhere": {
      "types": "./dist/drizzle/buildWhere.d.ts",
      "import": "./dist/drizzle/buildWhere.js",
      "default": "./dist/drizzle/buildWhere.js"
    },
    "./drizzle/buildOrderBy": {
      "types": "./dist/drizzle/buildOrderBy.d.ts",
      "import": "./dist/drizzle/buildOrderBy.js",
      "default": "./dist/drizzle/buildOrderBy.js"
    },
    "./drizzle/buildPagination": {
      "types": "./dist/drizzle/buildPagination.d.ts",
      "import": "./dist/drizzle/buildPagination.js",
      "default": "./dist/drizzle/buildPagination.js"
    },
    "./drizzle/upsert": {
      "types": "./dist/drizzle/upsert.d.ts",
      "import": "./dist/drizzle/upsert.js",
      "default": "./dist/drizzle/upsert.js"
    },
    "./drizzle/bulkInsert": {
      "types": "./dist/drizzle/bulkInsert.d.ts",
      "import": "./dist/drizzle/bulkInsert.js",
      "default": "./dist/drizzle/bulkInsert.js"
    },
    "./drizzle/collectSchemas": {
      "types": "./dist/drizzle/collectSchemas.d.ts",
      "import": "./dist/drizzle/collectSchemas.js",
      "default": "./dist/drizzle/collectSchemas.js"
    },
    "./drizzle/errors": {
      "types": "./dist/drizzle/errors.d.ts",
      "import": "./dist/drizzle/errors.js",
      "default": "./dist/drizzle/errors.js"
    },
    "./prisma": {
      "types": "./dist/prisma/index.d.ts",
      "import": "./dist/prisma/index.js",
      "default": "./dist/prisma/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "pretest": "prisma generate && DATABASE_URL=file:./test.db prisma db push --skip-generate",
    "test": "bun test"
  },
  "files": ["dist", "README.md", "docs", "prisma"],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.45.0 || ^1.0.0-beta",
    "@prisma/client": "^5.0.0 || ^6.0.0"
  },
  "peerDependenciesMeta": {
    "drizzle-orm": {
      "optional": true
    },
    "@prisma/client": {
      "optional": true
    }
  },
  "devDependencies": {
    "@justwant/tsconfig": "workspace:*",
    "@prisma/client": "^6.0.0",
    "better-sqlite3": "^11.0.0",
    "drizzle-orm": "^0.45.0",
    "prisma": "^6.0.0",
    "typescript": "^5.7.0"
  }
}
