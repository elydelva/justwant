{
  "name": "@justwant/core",
  "version": "0.2.1",
  "description": "Core shared utilities for the @justwant ecosystem: SQL helpers, mapping, query builders.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elydelva/justwant.git",
    "directory": "packages/core"
  },
  "keywords": [
    "dal",
    "database",
    "warehouse",
    "sql",
    "utils",
    "contract",
    "typescript"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "import": "./dist/db/index.js",
      "default": "./dist/db/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepublishOnly": "bun run typecheck && bun run build && bun test"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@justwant/contract": "workspace:*"
  },
  "devDependencies": {
    "@justwant/tsconfig": "workspace:*",
    "typescript": "^5.7.0"
  }
}
