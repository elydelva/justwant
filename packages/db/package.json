  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "pretest": "prisma generate && DATABASE_URL=file:./test.db prisma db push --skip-generate",
    "test": "bun test",
    "test:e2e:full": "bunx prisma generate && bunx prisma generate --schema=prisma/schema.postgres.prisma && bunx prisma generate --schema=prisma/schema.mysql.prisma && docker compose up -d && sleep 5 && DATABASE_URL=postgres://test:test@localhost:5432/justwant_test bunx prisma db push --schema=prisma/schema.postgres.prisma --skip-generate && DATABASE_URL=mysql://test:test@localhost:3306/justwant_test bunx prisma db push --schema=prisma/schema.mysql.prisma --skip-generate --accept-data-loss && bun test",
    "test:e2e:down": "docker compose down",
    "test:better-sqlite3": "bun run build && node scripts/better-sqlite3-e2e.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "docs",
    "prisma/schema.prisma"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@justwant/contract": "workspace:*",
    "@justwant/core": "workspace:*"
  },
  "peerDependencies": {
    "@standard-schema/spec": "^1.0.0",
    "drizzle-orm": "^0.45.0 || ^1.0.0-beta",
    "@prisma/client": "^5.0.0 || ^6.0.0",
    "waddler": "*"
  },
  "peerDependenciesMeta": {
    "@standard-schema/spec": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    },
    "@prisma/client": {
      "optional": true
    },
    "waddler": {
