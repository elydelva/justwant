  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.0",
    "@justwant/tsconfig": "workspace:*",
    "@prisma/client": "^6.0.0",
    "@standard-schema/spec": "^1.1.0",
    "@types/pg": "^8.18.0",
    "better-sqlite3": "^11.0.0",
    "drizzle-orm": "^0.45.0",
    "mysql2": "^3.11.0",
    "pg": "^8.13.0",
    "prisma": "^6.0.0",
    "typescript": "^5.7.0",
    "waddler": "*"
