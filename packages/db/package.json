{
  "name": "@justwant/db",
  "version": "0.4.2",
  "description": "Data Access Layer (DAL) for transactional databases. Contract-first, ORM-agnostic. Drizzle, Prisma, Waddler.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elydelva/justwant.git",
    "directory": "packages/db"
